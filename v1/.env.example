# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
DEVNET_KEYPAIR_PATH=./devnet.json

# Postgres
POSTGRES_URL=postgresql://user:password@localhost:5432/basira

# Storage (R2/S3)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=basira-deliverables

# LLM Judge
LLM_PROVIDER_KEY=your_llm_api_key

# Platform Keys — generate with `node scripts/keygen.mjs`, then paste pubkeys here.
# Secret keys live in keys/*.json (gitignored).
TREASURY_PUBKEY=
ARBITRATOR_PUBKEY=
KEEPER_PUBKEY=
UPGRADE_AUTHORITY_PUBKEY=

# Storage public domain (used for deliverable URLs after upload)
R2_PUBLIC_DOMAIN=https://deliverables.example.com
