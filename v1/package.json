{
  "name": "basira",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "web",
    "daemon"
  ],
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/dev.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/stop.ps1",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "daemon:dev": "npm run -w @basira/daemon dev",
    "daemon:e2e": "npm run -w @basira/daemon e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.2"
  }
}
