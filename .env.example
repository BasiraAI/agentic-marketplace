# Basira v1 — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# ─── Postgres ───────────────────────────────────────────────────────
# Neon connection string. Format:
# postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# ─── Solana ─────────────────────────────────────────────────────────
# RPC endpoint. Devnet for development, mainnet-beta for production.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Anchor program ID (filled in after Phase 1 deploys to devnet)
PROGRAM_ID=

# Keeper key path — used by daemon to sign relay transactions.
# Path to a JSON file containing the keypair (gitignored).
KEEPER_KEYPAIR_PATH=./keypairs/keeper.json

# Arbitrator key path — used by daemon for open_dispute / resolve_dispute.
ARBITRATOR_KEYPAIR_PATH=./keypairs/arbitrator.json

# ─── Object storage (Cloudflare R2 / S3) ────────────────────────────
# Optional for local dev. Leave blank to use the mock storage provider.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=basira-deliverables-dev
R2_ENDPOINT=

# ─── LLM judge ──────────────────────────────────────────────────────
# Provider: "mock" for tests, real provider name when chosen.
LLM_PROVIDER=mock
LLM_API_KEY=

# ─── Auth / signing secrets ─────────────────────────────────────────
# 32+ random bytes, hex or base64. Used to sign session tokens.
SESSION_SECRET=

# ─── App ────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Daemon ─────────────────────────────────────────────────────────
# Port for the daemon's /health endpoint (uptime monitor target).
HEALTH_PORT=8080
